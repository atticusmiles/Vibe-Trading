# ============================================================================
# LLM Configuration
# ============================================================================
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-your-key-here
LLM_MODEL_NAME=deepseek/deepseek-v3.2
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# ============================================================================
# Authentication (required — generate with: python -c "import secrets; print(secrets.token_hex(32))")
# ============================================================================
ENCRYPTION_KEY=
JWT_SECRET=

# ============================================================================
# Data Directory (optional — defaults to ./run locally, /data in Docker)
# ============================================================================
# DATA_DIR=./run

# ============================================================================
# Data Sources
# ============================================================================
TUSHARE_TOKEN=your-tushare-token

# ============================================================================
# API Server (optional)
# ============================================================================
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
# ENABLE_SESSION_RUNTIME=true
# VIBE_TRADING_TRUST_DOCKER_LOOPBACK=0
# VIBE_TRADING_ENABLE_SHELL_TOOLS=0
# VIBE_TRADING_ALLOWED_FILE_ROOTS=
# VIBE_TRADING_ALLOWED_RUN_ROOTS=

# ============================================================================
# Agent Tuning (optional)
# ============================================================================
# SWARM_WORKER_TIMEOUT=300
# SWARM_WORKER_MAX_ITER=50
# SWARM_MAX_WORKERS=4
# SWARM_TIMEOUT=1800
# SUBAGENT_TIMEOUT=300
# SUBAGENT_MAX_ITER=25
# TOKEN_THRESHOLD=40000

# ============================================================================
# Scheduler (optional — defaults shown below, Shanghai TZ, cron syntax)
# ============================================================================
# SCHEDULER_DIGEST_CRON=0 1 * * *             # Daily news digest
# SCHEDULER_CLEANUP_NEWS_CRON=0 3 * * *       # Old news cleanup
# SCHEDULER_SCAN_TRENDS_CRON=30 8 * * *       # Trend scan
# SCHEDULER_SCAN_INDUSTRIES_CRON=0 9 * * *    # Industry scan
# SCHEDULER_SCAN_STOCKS_CRON=30 9 * * *       # Stock scan
# SCHEDULER_REFRESH_TRENDS_CRON=0 10 * * *    # Trend refresh (保鲜)
# SCHEDULER_REFRESH_INDUSTRIES_CRON=30 10 * * *  # Industry refresh
# SCHEDULER_REFRESH_STOCKS_CRON=0 11 * * *    # Stock refresh
# SCHEDULER_AUTO_RESEARCH_CRON=30 11 * * *    # Auto-research
# SCHEDULER_AUTO_RESEARCH_CONCURRENT=4     # Max concurrent auto-research runs
# SCHEDULER_RESEARCH_TIMEOUT_MINUTES=30    # Stuck/zombie research timeout
# SCHEDULER_NEWS_RETENTION_DAYS=7          # Delete news older than N days
# SCHEDULER_REJECTED_WINDOW_DAYS=7         # Rejected candidate dedup window
# SCHEDULER_REFRESH_CUTOFF_HOURS=24        # Entity refresh staleness threshold
